<nav class="fixed top-0 left-0 right-0 bg-[#1E3A8A] shadow-lg z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center py-4">
        <% if (currentPage === 'curriculo') { %>
          <a href="/portfolio" class="text-xl text-white hover:text-[#38BDF8]">
            <i class="fas fa-arrow-left"></i>
          </a>
        <% } else { %>
          <span class="text-white font-display font-bold text-xl">Pedro-<span
              class="text-[#38BDF8]">Portfolio</span></span>
        <% } %>
      </div>

      <% if (currentPage === 'index') { %>
        <div class="hidden md:block">
          <ul class="flex space-x-8" id="menuDesktop">
            <% header.menuItems.forEach(function(item) { %>
              <% let linkHref = item.href; %>
              <% if (currentPage !== 'index' && item.href.startsWith('#')) { linkHref = './' + item.href; } %>
              <% if (currentPage === 'curriculo' && item.title === 'Curriculo') { linkHref = '#'; } %>
              <li>
                <a class="text-white hover:text-[#38BDF8] py-2 px-3 rounded-md transition duration-300 font-medium text-center"
                  href="<%= linkHref %>">
                  <%= item.title %>
                </a>
              </li>
              <% }); %>
          </ul>
        </div>

        <button class="md:hidden p-2 text-white focus:outline-none" type="button"
          onclick="document.getElementById('mobileMenu').classList.toggle('hidden')">
          <i class="fas fa-bars text-xl"></i>
        </button>
      <% } %>
    </div>

    <% if (currentPage === 'index') { %>
      <div class="hidden md:hidden" id="mobileMenu">
        <ul class="pt-2 pb-4 space-y-2" id="menuItems">
          <% header.menuItems.forEach(function(item) { %>
            <% let linkHref = item.href; %>
            <% if (currentPage !== 'index' && item.href.startsWith('#')) { linkHref = '../' + item.href; } %>
            <% if (currentPage === 'curriculo' && item.title === 'Curriculo') { linkHref = '#'; } %>
            <li>
              <a class="block py-2 px-4 text-white hover:bg-[#2A4594] rounded-md transition duration-300"
                href="<%= linkHref %>">
                <%= item.title %>
              </a>
            </li>
            <% }); %>
        </ul>
      </div>
    <% } %>
  </div>
</nav>